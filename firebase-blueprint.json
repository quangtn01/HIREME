{
  "entities": {
    "Campus": {
      "title": "Campus",
      "description": "A physical location with multiple classrooms.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the campus" },
        "rooms": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of room names in this campus"
        }
      },
      "required": ["name", "rooms"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Company employees with detailed information.",
      "type": "object",
      "properties": {
        "staffId": { "type": "string", "description": "Employee ID (NV001, NV002...)" },
        "name": { "type": "string", "description": "Full name" },
        "jobTitleIds": { "type": "array", "items": { "type": "string" }, "description": "List of Job Title IDs" },
        "departmentIds": { "type": "array", "items": { "type": "string" }, "description": "List of Department IDs" },
        "status": { "type": "string", "enum": ["Working", "Resigned"], "description": "Employment status" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "birthDate": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "citizenId": { "type": "string" },
        "citizenIdDate": { "type": "string" },
        "socialInsuranceId": { "type": "string" },
        "healthInsuranceId": { "type": "string" },
        "childrenCount": { "type": "number", "minimum": 0, "maximum": 3 },
        "emergencyContact": { "type": "string" },
        "degrees": { "type": "string" },
        "certificates": { "type": "string" },
        "bankAccount": { "type": "string" },
        "bankName": { "type": "string" }
      },
      "required": ["staffId", "name", "status"]
    },
    "Class": {
      "title": "Class",
      "description": "An active or archived class with detailed info.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Class name" },
        "programId": { "type": "string", "description": "ID of the program" },
        "status": { "type": "string", "enum": ["Active", "Archived"], "description": "Current status" },
        "teacherId": { "type": "string", "description": "ID of the teacher" },
        "taId": { "type": "string", "description": "ID of the TA" },
        "startDate": { "type": "string", "description": "Start date (YYYY-MM-DD)" },
        "endDate": { "type": "string", "description": "End date (YYYY-MM-DD)" },
        "tuitionFull": { "type": "number", "description": "Full course tuition fee" },
        "tuitionMonthly": { "type": "number", "description": "Monthly tuition fee" },
        "schedule": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dayOfWeek": { "type": "number" },
              "campusId": { "type": "string" },
              "room": { "type": "string" },
              "slot": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "programId", "status", "teacherId", "startDate", "endDate"]
    },
    "Program": {
      "title": "Program",
      "description": "A study program name.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Program name" }
      },
      "required": ["name"]
    },
    "JobTitle": {
      "title": "Job Title",
      "description": "A job title in the company.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Job title name" }
      },
      "required": ["name"]
    },
    "Department": {
      "title": "Department",
      "description": "A department in the center.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Department name" }
      },
      "required": ["name"]
    },
    "Session": {
      "title": "Session",
      "description": "A specific teaching session scheduled in a room.",
      "type": "object",
      "properties": {
        "classId": { "type": "string", "description": "ID of the class" },
        "teacherId": { "type": "string", "description": "ID of the teacher" },
        "taId": { "type": "string", "description": "ID of the TA" },
        "campusId": { "type": "string", "description": "ID of the campus" },
        "room": { "type": "string", "description": "Room name" },
        "startTime": { "type": "string", "format": "date-time", "description": "ISO start time" },
        "endTime": { "type": "string", "format": "date-time", "description": "ISO end time" },
        "zoomId": { "type": "string", "description": "Zoom meeting ID or room number" },
        "weekStart": { "type": "string", "description": "Monday of the week (YYYY-MM-DD) for easier filtering" }
      },
      "required": ["classId", "teacherId", "campusId", "room", "startTime", "endTime", "weekStart"]
    },
    "LeaveUsage": {
      "title": "Leave Usage",
      "description": "A record of staff leave usage.",
      "type": "object",
      "properties": {
        "staffId": { "type": "string", "description": "ID of the staff member" },
        "date": { "type": "string", "description": "Date of leave (YYYY-MM-DD)" },
        "days": { "type": "number", "description": "Number of days taken" },
        "reason": { "type": "string", "description": "Reason for leave" }
      },
      "required": ["staffId", "date", "days"]
    },
    "Student": {
      "title": "Student",
      "description": "A student enrolled in the center.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Student ID (HV000001, HV000002...)" },
        "name": { "type": "string", "description": "Full name" },
        "nickname": { "type": "string", "description": "Nickname" },
        "status": { "type": "string", "enum": ["Study", "Trial", "Pending", "Done"], "description": "Current status" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "birthYear": { "type": "number", "description": "Year of birth" },
        "phone": { "type": "string", "description": "Phone number" },
        "classIds": { "type": "array", "items": { "type": "string" }, "description": "List of Class IDs" },
        "email": { "type": "string", "description": "Email address" },
        "facebook": { "type": "string", "description": "Facebook profile link" },
        "school": { "type": "string", "description": "Current school" },
        "parentName": { "type": "string", "description": "Parent's name" },
        "parentPhone": { "type": "string", "description": "Parent's phone number" },
        "note": { "type": "string", "description": "Additional notes" }
      },
      "required": ["studentId", "name", "status"]
    }
  },
  "firestore": {
    "campuses": { "schema": "Campus", "description": "Collection of campuses" },
    "staff": { "schema": "Staff", "description": "Collection of staff members" },
    "classes": { "schema": "Class", "description": "Collection of classes" },
    "programs": { "schema": "Program", "description": "Collection of study programs" },
    "jobTitles": { "schema": "JobTitle", "description": "Collection of job titles" },
    "departments": { "schema": "Department", "description": "Collection of departments" },
    "sessions": { "schema": "Session", "description": "Collection of scheduled sessions" },
    "leaveUsage": { "schema": "LeaveUsage", "description": "Collection of leave usage records" },
    "students": { "schema": "Student", "description": "Collection of students" }
  }
}
